<!DOCTYPE html>
<html>
<head>
  <title><%= content_for?(:title) ? yield(:title) : Fuik::Engine.config.title %></title>
  <%= csrf_meta_tags %>
  <%= csp_meta_tag %>

  <%= yield :head %>

  <style>
    :root {
      color-scheme: <%= {
        auto: "light dark",
        light: "light",
        dark: "dark"
      }.fetch(Fuik::Engine.config.color_scheme.to_sym) %>;
    }
  </style>

  <%= stylesheet_link_tag "fuik/application", media: "all" %>
  <script src="<%= asset_path("attractivejs-0.12.0.min.js") %>"></script>
</head>
<body>
  <main>
    <%= yield %>
  </main>
</body>
</html>
